# =============================================================
# RenVault Frontend — Environment Variables
# Copy this file to .env.local and fill in real values.
# =============================================================

# WalletConnect project ID (required)
REACT_APP_WALLETCONNECT_PROJECT_ID=your_project_id_here

# App metadata
REACT_APP_NAME=RenVault Wallet
REACT_APP_DESCRIPTION=RenVault Web Wallet
REACT_APP_URL=http://localhost:3000
REACT_APP_ICON=

# API endpoints
REACT_APP_ANALYTICS_API_URL=
REACT_APP_NOTIFICATIONS_API_URL=
REACT_APP_SPONSORSHIP_API_URL=
REACT_APP_CORE_API_URL=

# RenVault contract coordinates
# Set these to override the built-in defaults (useful for testnet / staging).
# REACT_APP_CONTRACT_ADDRESS accepts either a bare Stacks principal
# (e.g. SP2J6ZY48GV1EZ5V2V5RB9MP66SW86PYKKNRV9EJ7) OR a fully-qualified
# contract identifier (e.g. SP2J6ZY48GV1EZ5V2V5RB9MP66SW86PYKKNRV9EJ7.ren-vault).
REACT_APP_CONTRACT_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM
REACT_APP_CONTRACT_NAME=ren-vault
